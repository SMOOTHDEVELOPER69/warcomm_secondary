{
  "name": "mesh-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup:prototype": "cd prototype_code && npm install",
    "run:prototype-ws": "cd prototype_code && node server.js",
    "run:prototype-client": "cd prototype_code && npx next dev -p 3001",
    "start:local": "npm run setup:prototype && concurrently \"npm run dev\" \"npm run run:prototype-ws\" \"npm run run:prototype-client\""
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
